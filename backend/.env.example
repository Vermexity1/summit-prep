# Summit Prep backend env
# Leave MONGODB_URI empty to keep using the local JSON file store.
# Paste your Atlas URI and restart the backend when you're ready to switch.

PORT=4000
DATA_FILE=./src/data/app-data.json
DATABASE_PROVIDER=mongodb
MONGODB_URI=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_PROVIDER=local
SESSION_SECRET=summit-prep-local-secret
AI_MODE=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
